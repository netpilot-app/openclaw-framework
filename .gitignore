# OpenClaw Framework .gitignore

# Personal/secret files — never commit these
.env
.env.*
*.token
*token*
*secret*
auth.json
auth-profiles.json
*credentials*
*.key

# OpenClaw state
.openclaw/agents/
*.sqlite
*.sqlite-wal
*.sqlite-shm

# Logs
*.log
logs/

# Node
node_modules/
.npm/

# OS files
.DS_Store
Thumbs.db
*.swp
*.swo

# Editor
.vscode/settings.json
.idea/

# Personal memory — DO NOT commit these to shared repos
# (comment out if this IS your personal workspace repo)
# MEMORY.md
# memory/
# brain/council/
