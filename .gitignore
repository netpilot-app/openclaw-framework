# OpenClaw Framework — Git Ignore

# Memory files (personal, don't commit)
/memory/
/memory/*.md

# Environment files
.env
.env.local
.env.*.local

# Logs
*.log
/var/log/

# OS files
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Node
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Backup files
*.bak
*.bak.*
